# Copy to .env and adjust. docker-compose reads this file.

# --- shared secret used by server (to validate) and agent (to enroll) ---
SENTINEL_ENROLL_TOKEN=change-me-enrollment-token

# --- console admin (dev convenience; REQUIRED + strong in production) ---
SENTINEL_ADMIN_USER=admin
SENTINEL_ADMIN_PASS=sentinel-admin

# --- server ---
# development | production  (production enforces TLS + strong secrets, see config.Validate)
SENTINEL_ENV=development
# HS256 signing secret for console JWTs (>=32 chars). Generated per-run in dev if empty.
SENTINEL_JWT_SECRET=
# Restrict console origins in production, e.g. https://soc.example.com
SENTINEL_ALLOW_ORIGINS=
# Only these reverse proxies may set X-Forwarded-For, e.g. 10.0.0.0/8,127.0.0.1
SENTINEL_TRUSTED_PROXIES=

# --- database (TimescaleDB) ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel

# --- TLS / mTLS (production) ---
# SENTINEL_TLS_CERT=/certs/server.crt
# SENTINEL_TLS_KEY=/certs/server.key
# SENTINEL_TLS_CLIENT_CA=/certs/ca.crt   # enables mutual TLS for agents

# --- agent TLS / mTLS (used by sentinel-agent) ---
# SENTINEL_AGENT_TLS_CA=/certs/ca.crt
# SENTINEL_AGENT_TLS_CERT=/certs/agent.crt
# SENTINEL_AGENT_TLS_KEY=/certs/agent.key
