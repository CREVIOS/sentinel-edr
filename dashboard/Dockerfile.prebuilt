# Runtime image from a PRE-BUILT standalone output (no in-image `next build`, so the
# Docker daemon's build cgroup can't OOM-kill it). Build the artifact first with a plain
# `docker run -m …` (see deploy notes), which produces .next/standalone here.
FROM node:22-bookworm-slim
WORKDIR /app
ENV NODE_ENV=production NEXT_TELEMETRY_DISABLED=1 PORT=3000 HOSTNAME=0.0.0.0
COPY .next/standalone ./
COPY .next/static ./.next/static
COPY public ./public
EXPOSE 3000
CMD ["node", "server.js"]
