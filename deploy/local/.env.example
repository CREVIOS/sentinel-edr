# Sentinel EDR — LOCAL-SERVER deploy config.
#
# Copy to .env (git-ignored) and fill in, OR just run ./deploy.sh — it creates .env from this
# file on first run and AUTO-GENERATES every secret (marked "auto" below) with `openssl rand`.
# Re-running deploy.sh never overwrites an existing .env.
#
#   cp .env.example .env     # optional; deploy.sh does this for you
#   ./deploy.sh

# --- public entry point ---------------------------------------------------------------------
# The base URL browsers use to reach the console. Must match the origin exactly (scheme + host
# + port). Used for CORS allow-list (server) and Better Auth's base URL (dashboard).
#   http://localhost            (default, port 80)
#   http://192.168.1.50:8088    (LAN IP + custom port)
SENTINEL_HOST=http://localhost
# Host port nginx publishes. If not 80, include it in SENTINEL_HOST above.
HTTP_PORT=80

# --- secrets (auto-generated by deploy.sh if left blank) ------------------------------------
# Postgres password.                                                                     [auto]
PGPW=
# NATS auth token (event bus + command mesh).                                            [auto]
NATS_TOKEN=
# HS256 signing secret for the Go control-plane console JWTs (>=32 chars).               [auto]
SENTINEL_JWT_SECRET=
# Shared secret an agent must present to enroll.                                         [auto]
SENTINEL_ENROLL_TOKEN=
# Better Auth signing secret (dashboard session cookies).                               [auto]
BETTER_AUTH_SECRET=

# --- Go service account -----------------------------------------------------------------------
# The dashboard BFF authenticates to the Go API as this account (and the server bootstraps it).
SENTINEL_ADMIN_USER=admin
# SENTINEL_ADMIN_PASS — service-account password.                                        [auto]
SENTINEL_ADMIN_PASS=

# --- console operator (your login) ----------------------------------------------------------
# deploy.sh seeds this Better Auth operator so you can log into the dashboard. Password must be
# >= 12 chars (Better Auth minPasswordLength).
CONSOLE_ADMIN_EMAIL=admin@sentinel.local
# CONSOLE_ADMIN_PASS — your console login password.                                      [auto]
CONSOLE_ADMIN_PASS=
# Role for the seeded operator: viewer | analyst | admin
CONSOLE_ADMIN_ROLE=admin

# --- threat intel (optional) ----------------------------------------------------------------
# Comma-separated remote IOC feed URLs. Leave the default for live abuse.ch C2 blocklists, or
# set to empty for a fully air-gapped box.
# SENTINEL_IOC_FEEDS=https://feodotracker.abuse.ch/downloads/ipblocklist.txt,https://sslbl.abuse.ch/blacklist/sslipblacklist.txt
